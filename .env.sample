# Stripe test mode configuration
# IMPORTANT: use only test keys (sk_test_... and pk_test_...).
# Do not use live keys in local development.

# Backend (Django)
# Stripe Dashboard -> Developers -> API keys -> Secret key (test): sk_test_...
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe Dashboard -> Developers -> Webhooks -> Select endpoint -> Signing secret: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# success/cancel URLs are resolved in code from relative paths: /success and /cancel
# Backend builds the absolute Stripe return URL from the frontend request origin.

# Frontend (Next.js)
# Public key exposed to browser bundle (safe for client-side use in test mode).
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Test card for Stripe Checkout
# 4242 4242 4242 4242
# Any future date, any CVC, any ZIP.
